# Public frontend variables used by the landing page and authenticated CRM.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLIC_SUPABASE_ANON_KEY

# Optional custom intake endpoint for lead capture.
# When empty, the frontend falls back to ${VITE_SUPABASE_URL}/rest/v1/leads.
VITE_SUPABASE_INTAKE_URL=

# Optional automation webhook. Keep empty when there is no external workflow.
VITE_N8N_WEBHOOK_URL=
